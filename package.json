{
  "name": "community-platform-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "worker:transcription": "node --watch queue/workers/transcriptionWorker.js",
    "worker:llm": "node --watch queue/workers/llmWorker.js",
    "backfill:embeddings": "node db/backfillEmbeddings.js",
    "workers": "concurrently -n transcription,llm -c blue,magenta \"npm:worker:transcription\" \"npm:worker:llm\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.1040.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mammoth": "^1.12.0",
    "multer": "^1.4.4",
    "openai": "^4.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "socket.io": "^4.0.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
